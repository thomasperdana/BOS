# Environment variables for Bible Operating System (BOS) app

# API Keys
NEXT_PUBLIC_PUTER_API_KEY=your_puter_api_key
NEXT_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key
NEXT_PUBLIC_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# GitHub Configuration
GITHUB_PAT_API_KEY=your_github_personal_access_token
GITHUB_REPO_URL=your_github_repository_url
GITHUB_BRANCH=your_github_branch

# Authentication
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXT_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your_facebook_webhook_verify_token
FACEBOOK_APP_SECRET=your_facebook_app_secret
NEXT_PUBLIC_FACEBOOK_GROUP_ID=your_facebook_group_id

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_google_analytics_id

# Deployment
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Feature Flags
NEXT_PUBLIC_ENABLE_FACEBOOK_INTEGRATION=true
NEXT_PUBLIC_ENABLE_COMMUNITY_FEATURES=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true

# Performance
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_CACHE_MAX_AGE=31536000
