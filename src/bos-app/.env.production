# Production Environment Configuration
# This file contains environment variables for production deployment

# API Keys (replace with actual production keys)
NEXT_PUBLIC_PUTER_API_KEY=your-production-puter-api-key
NEXT_PUBLIC_OPENROUTER_API_KEY=your-production-openrouter-api-key
NEXT_PUBLIC_GEMINI_PRO_API_KEY=your-production-gemini-pro-api-key

# Authentication
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-production-google-client-id
NEXT_PUBLIC_FACEBOOK_APP_ID=your-production-facebook-app-id

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Deployment
NEXT_PUBLIC_SITE_URL=https://bible-os.com
NEXT_PUBLIC_API_URL=https://api.bible-os.com

# Feature Flags
NEXT_PUBLIC_ENABLE_FACEBOOK_INTEGRATION=true
NEXT_PUBLIC_ENABLE_COMMUNITY_FEATURES=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true

# Performance
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_CACHE_MAX_AGE=31536000
